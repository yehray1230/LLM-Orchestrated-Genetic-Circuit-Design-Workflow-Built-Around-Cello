{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/workflow-kit-schema.json",
  "title": "Workflow Kit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "schema_version",
    "version",
    "summary",
    "entrypoint",
    "agents",
    "stages",
    "inputs",
    "outputs",
    "claim_level",
    "requires_expert_review"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "workflow-kit-v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "agent": {
            "type": "string"
          },
          "tool": {
            "type": "string"
          },
          "optional": {
            "type": "boolean"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_settings": {
      "type": "object"
    },
    "sample_prompts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_level": {
      "enum": [
        "planning_only",
        "computational_candidate",
        "cello_compatible_candidate",
        "simulation_screening",
        "workflow_memory"
      ]
    },
    "requires_expert_review": {
      "type": "boolean"
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
