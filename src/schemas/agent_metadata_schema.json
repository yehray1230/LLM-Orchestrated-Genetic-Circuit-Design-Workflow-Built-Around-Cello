{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/agent-metadata-schema.json",
  "title": "Agent Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "schema_version",
    "module",
    "entrypoint",
    "role",
    "summary",
    "inputs",
    "outputs",
    "claim_level",
    "requires_expert_review"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "agent-metadata-v1"
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "downstream_agents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_level": {
      "enum": [
        "planning_only",
        "computational_candidate",
        "cello_compatible_candidate",
        "simulation_screening",
        "workflow_memory"
      ]
    },
    "requires_expert_review": {
      "type": "boolean"
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
